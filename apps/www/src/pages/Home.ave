<script lang="ts">
  import { signal } from '@avedon/runtime'

  const selected = signal('npm')
  const cmd = signal('npm create avedon-app')
  const copied = signal(false)

  function pickNpm() {
    selected.set('npm')
    cmd.set('npm create avedon-app')
    copied.set(false)
  }

  function pickPnpm() {
    selected.set('pnpm')
    cmd.set('pnpm create avedon-app')
    copied.set(false)
  }

  function pickYarn() {
    selected.set('yarn')
    cmd.set('yarn create avedon-app')
    copied.set(false)
  }

  function pickBun() {
    selected.set('bun')
    cmd.set('bun create avedon-app')
    copied.set(false)
  }

  async function copyCmd() {
    try {
      await navigator.clipboard.writeText(cmd.get())
      copied.set(true)
      setTimeout(() => copied.set(false), 1600)
    } catch {
      copied.set(false)
    }
  }
</script>

<script server>
  export async function load() {
    return {}
  }
</script>

