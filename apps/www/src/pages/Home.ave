<template>
  <main class="stage" data-www-stage>
    <div class="stage-glow" aria-hidden="true"></div>
    <div class="stage-grid" aria-hidden="true"></div>
    <p class="brand">avedon</p>
    <h1 class="headline">TypeScript-first full-stack web framework.</h1>
    <p class="support">
      One .ave file for UI, styles, and server logic — explicit routes, hybrid rendering, Vite
      toolchain.
    </p>
    <div class="install">
      <div class="install-tabs" role="tablist" aria-label="Package manager">
        <button type="button" role="tab" class={selected.get() === 'npm' ? 'active' : ''} on:click={pickNpm}>npm</button>
        <button type="button" role="tab" class={selected.get() === 'pnpm' ? 'active' : ''} on:click={pickPnpm}>pnpm</button>
        <button type="button" role="tab" class={selected.get() === 'yarn' ? 'active' : ''} on:click={pickYarn}>yarn</button>
        <button type="button" role="tab" class={selected.get() === 'bun' ? 'active' : ''} on:click={pickBun}>bun</button>
      </div>
      <div class="install-row">
        <code>{cmd}</code>
        <button type="button" on:click={copyCmd}>{copied.get() ? 'Copied' : 'Copy'}</button>
      </div>
    </div>
    <div class="ctas">
      <a class="cta-primary" href="/docs/quick-start/">Get started</a>
      <a class="cta-secondary" href="https://github.com/avedonjs/avedon" rel="noopener noreferrer" target="_blank">GitHub</a>
    </div>
  </main>
</template>
