  }

  .docs-shell .toc nav {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .docs-shell .toc a {
    display: flex;
    align-items: center;
    min-height: 44px;
    padding: 0.25rem 0;
    color: var(--muted);
    text-decoration: none;
  }

  .docs-shell .toc a:hover {
    color: var(--fg);
  }

  .docs-shell .toc .h3 {
    padding-left: 0.75rem;
  }

  @media (max-width: 960px) {
    .docs-shell {
      grid-template-columns: minmax(12rem, 14rem) minmax(0, 1fr);
    }

    .docs-shell .toc {
      display: none;
    }
  }

  @media (max-width: 720px) {
    .docs-shell {
      grid-template-columns: 1fr;
    }

    .docs-shell .side {
      position: static;
      max-height: none;
      border-right: none;
      border-bottom: 1px solid var(--line);
      padding-right: 0;
      padding-bottom: 1rem;
    }
  }
</style>

<template>
  <div class="docs-shell">
    <aside class="side">
      {#each groups as g}
        <div class="group">
          <p class="group-title">{g.title}</p>
          <nav aria-label={g.title}>
            {#each g.docs as d}
              <a href={'/docs/' + d.slug + '/'} class={d.slug === slug ? 'active' : ''}>{d.title}</a>
            {/each}
          </nav>
        </div>
      {/each}
    </aside>
    <article class="prose">
      {@html html}
      <nav class="pager" aria-label="Previous and next">
        {#if prev}
          <a href={'/docs/' + prev.slug + '/'}>
            <span class="label">Previous</span>
            {prev.title}
          </a>
        {/if}
        {#if next}
          <a class="next" href={'/docs/' + next.slug + '/'}>
            <span class="label">Next</span>
            {next.title}
          </a>
        {/if}
      </nav>
    </article>
    <aside class="toc">
      {#if headings.length}
        <p>On this page</p>
        <nav aria-label="On this page">
          {#each headings as h}
            <a href={'#' + h.id} class={h.level === 3 ? 'h3' : ''}>{h.text}</a>
          {/each}
        </nav>
      {/if}
    </aside>
  </div>
</template>
