<script lang="ts">
  export let html
  export let headings
  export let groups
  export let slug
  export let title
  export let prev
  export let next
</script>

<script server>
  import { notFound } from '@avedon/server'
  import { getAdjacentDocs, getDoc, listNavGroups } from '../lib/docs'

  export async function load({ params }) {
    const entry = getDoc(params.slug)
    if (!entry) throw notFound()
    const { prev, next } = getAdjacentDocs(entry.slug)
    return {
      title: entry.title,
      html: entry.html,
      headings: entry.headings,
      groups: listNavGroups(false),
      slug: entry.slug,
      prev,
      next,
    }
  }
</script>

<style unscoped>
  .docs-shell {
    display: grid;
    grid-template-columns: minmax(12rem, 16rem) minmax(0, 1fr) minmax(10rem, 14rem);
    gap: 2rem;
    width: min(100%, 80rem);
    margin: 0 auto;
    padding: 1.5rem clamp(1rem, 3vw, 2rem) 3rem;
    box-sizing: border-box;
  }

  .docs-shell .side {
    border-right: 1px solid var(--line);
    padding-right: 1rem;
    position: sticky;
    top: 1rem;
    align-self: start;
    max-height: calc(100vh - 2rem);
    overflow: auto;
  }

  .docs-shell .side .group {
    margin-bottom: 1.25rem;
  }

  .docs-shell .side .group-title {
    margin: 0 0 0.5rem;
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .docs-shell .side nav {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .docs-shell .side a {
    display: flex;
    align-items: center;
    min-height: 44px;
    padding: 0.35rem 0.25rem;
    color: var(--muted);
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
  }

  .docs-shell .side a:hover,
  .docs-shell .side a.active {
    color: var(--fg);
  }

  .docs-shell .side a.active {
    color: var(--accent);
  }

  .docs-shell .prose {
    max-width: 42rem;
    line-height: 1.6;
    font-size: 1.02rem;
  }

  .docs-shell .prose a {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  .docs-shell .prose h1 {
    margin: 0 0 1rem;
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    letter-spacing: -0.03em;
    line-height: 1.15;
  }

  .docs-shell .prose h2 {
    margin: 2rem 0 0.75rem;
    font-size: 1.35rem;
    letter-spacing: -0.02em;
  }

  .docs-shell .prose h3 {
    margin: 1.5rem 0 0.5rem;
    font-size: 1.1rem;
  }

  .docs-shell .prose p,
  .docs-shell .prose ul,
  .docs-shell .prose ol {
    margin: 0 0 1rem;
  }

  .docs-shell .prose li {
    margin-bottom: 0.35rem;
