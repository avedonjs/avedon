  }

  .docs-shell .prose :not(pre) > code {
    padding: 0.1em 0.35em;
    border-radius: 0.25rem;
    background: rgba(250, 250, 250, 0.06);
  }

  .docs-shell .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 1.25rem;
    font-size: 0.95rem;
  }

  .docs-shell .prose th,
  .docs-shell .prose td {
    border: 1px solid var(--line);
