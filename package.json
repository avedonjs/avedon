{
  "name": "avedon",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build --filter=!example",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:smoke": "node e2e/smoke.mjs && node e2e/create-smoke.mjs && node e2e/isr-smoke.mjs && node e2e/ttfb-smoke.mjs && node e2e/stream-redirect-smoke.mjs && node e2e/create-pack-smoke.mjs",
    "typecheck": "turbo run typecheck && tsc -p tsconfig.typecheck.json --noEmit",
    "dev": "pnpm -F example dev"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@playwright/test": "^1.51.0",
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
