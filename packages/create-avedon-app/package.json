{
  "name": "create-avedon-app",
  "version": "0.1.1",
  "type": "module",
  "description": "Scaffold a new avedon app",
  "bin": {
    "create-avedon-app": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "template"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/avedonjs/avedon.git",
    "directory": "packages/create-avedon-app"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
