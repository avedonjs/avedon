{
  "name": "@vexjs/compiler",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@vexjs/runtime": "workspace:*",
    "@vexjs/shared": "workspace:*",
    "typescript": "^5.8.2"
  },
  "devDependencies": {
    "tsup": "^8.4.0"
  }
}
